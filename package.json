{
    "name": "obsidian-chopro-plugin",
    "version": "0.9.4",
    "description": "Render ChoPro format chord sheets",
    "author": "Jason Heddings",
    "license": "MIT",
    "main": "main.js",
    "scripts": {
        "prepare": "husky",
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "test": "vitest run"
    },
    "keywords": [
        "obsidian",
        "plugin",
        "chopro",
        "chords",
        "music"
    ],
    "devDependencies": {
        "@types/node": "^24.12.4",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "esbuild": "0.28.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-obsidianmd": "^0.3.0",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "nano-staged": "^1.0.2",
        "obsidian": "latest",
        "prettier": "^3.8.3",
        "tslib": "2.8.1",
        "typescript": "6.0.3",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "obskit": "^2.0.0",
        "yaml": "^2.9.0"
    },
    "nano-staged": {
        "*.{js,jsx,ts,tsx,json,css,scss}": [
            "prettier --check",
            "eslint"
        ],
        "*.md": [
            "prettier --check"
        ]
    }
}
